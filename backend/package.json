{
  "name": "backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --env-file=../.env.local run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "start:staging": "bun --env-file=../.env.staging run src/index.ts",
    "start:prod": "bun --env-file=../.env.production run src/index.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "bun --env-file=../.env.local run src/db/seed-challenges.ts",
    "db:reset": "powershell -ExecutionPolicy Bypass -File ./scripts/reset-db.ps1",
    "db:reset:bash": "bash ./scripts/reset-db.sh"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "drizzle-orm": "^0.45.1",
    "google-auth-library": "^10.5.0",
    "jsonwebtoken": "^9.0.3",
    "postgres": "^3.4.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/pg": "^8.16.0",
    "drizzle-kit": "^0.31.8"
  }
}
